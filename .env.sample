MISTRAL_API_KEY="your_api_key_here"

# PostgreSQL via `mise run dev` (scripts/run-dev-postgres.sh → port AGENTPLANE_PG_PORT / 55432).
# Uncomment after Docker is installed; Postgres must be up before migrate if DATABASE_URL is set.
# DATABASE_URL=postgresql://agentplane:agentplane@127.0.0.1:55432/agentplane

# Optional; defaults in settings work for bundled llama-server
# LOCAL_LLM_BASE_URL=http://127.0.0.1:8765/v1
# LOCAL_LLM_MODEL=gemma-2-2b-it
# OPENAI_API_KEY=sk-local-provider
