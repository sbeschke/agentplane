#!/usr/bin/env bash
#MISE description="Initialise the development environment (tools, deps, DB migrations, prek hooks, llama-server runtime, local GGUF weights)"
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

mise install
uv sync
uv run --env-file .env python manage.py migrate
prek install --prepare-hooks
bash scripts/download_llama_runtime.sh
bash scripts/download_local_llm.sh
